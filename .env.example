# ============================================================
#  Local development environment for the GSR ADK backend
#  (used by docker-compose / run.sh)
#  Copy to .env:   cp .env.example .env
#  .env is git-ignored — never commit real secrets.
# ============================================================

# ---- LLM (Google AI Studio key — no GCP project required) --
GEMINI_API_KEY=replace-with-your-ai-studio-key

# ---- Object storage --------------------------------------
# S3-compatible: MinIO locally (via docker-compose), Cloudflare R2 in prod.
S3_BUCKET=gsr-eval-results-local
S3_REVIEW_BUCKET=gsr-review-results-local
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=auto
# Leave S3_ENDPOINT unset to use the local MinIO container. To point local
# dev at your real Cloudflare R2 bucket instead, set it here:
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# ---- UI login -----------------------------------------------
# Gates the browser UI and API behind a password. Leave unset to disable
# login for local dev (the default). REQUIRED in production — the server
# refuses to start without it; set a real value via `fly secrets set`.
# UI_PASSWORD=replace-with-a-strong-password
# Optional: signs the session cookie instead of UI_PASSWORD itself. Falls
# back to UI_PASSWORD if unset.
# SESSION_SECRET=replace-with-a-different-random-value
