# ============================================================
#  Local development environment for the GSR ADK backend
#  Copy to .env:   cp .env.example .env
#  .env is git-ignored — never commit real secrets.
# ============================================================

# ---- LLM (Google AI Studio key — no GCP project required) --
GEMINI_API_KEY=replace-with-your-ai-studio-key
# GEMINI_MODEL=gemini-3.1-pro-preview

# ---- Object storage (S3-compatible: Cloudflare R2 in prod, MinIO locally) --
S3_BUCKET=gsr-eval-results-local
S3_REVIEW_BUCKET=gsr-review-results-local
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=auto
# Leave S3_ENDPOINT unset to use the local MinIO container (via
# docker-compose). To point local dev at your real Cloudflare R2 bucket
# instead, set it here:
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# ---- Evaluator cross-service call ---------------------------
# URL of the deployed tools/eval Fly app, used by the "Evaluate on
# Production" button. Only needed if you exercise that flow locally.
# EVALUATOR_SERVICE_URL=https://gsr-evaluator.fly.dev
# Shared secret attached as X-Internal-Key on that call — must match the
# same value set on the gsr-evaluator app for the call to be accepted.
# EVALUATOR_SHARED_SECRET=replace-with-a-random-value

# ---- UI login -----------------------------------------------
# Gates the browser UI and all /api/* routes (except /api/status) behind a
# password + signed cookie session. Leave unset to disable login entirely
# (default for local dev) — set it via `fly secrets set` in production.
# UI_PASSWORD=replace-with-a-strong-password

# ---- Server -----------------------------------------------
PORT=8080
