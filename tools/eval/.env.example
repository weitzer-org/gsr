# GSR Evaluation Testing Environment

# ---- Object storage (S3-compatible: Cloudflare R2 in prod, MinIO locally) --
S3_BUCKET="gsr-eval-results"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_REGION="auto"
# Leave unset to use local MinIO (via docker-compose). Point at your real R2
# bucket for production runs:
#   S3_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"

# ---- Credentials ------------------------------------------
GITHUB_TOKEN="ghp_..."
# GEMINI_API_KEY="AIza..." # Google AI Studio key — no GCP project required

# ---- Inbound auth for /api/evaluate ------------------------
# Shared secret checked against the X-Internal-Key header on requests to
# this service's /api/evaluate — must match the value the main backend
# (adk/backend) sends. Leave unset to disable the check (local dev default).
# REQUIRED in production (NODE_ENV=production) — this service has no other
# auth of its own, so it refuses to start without it.
# EVALUATOR_SHARED_SECRET="replace-with-a-random-value"

# ---- Branch comparisons (local_vs_branch / branch_vs_production) ----------
# Auto-deploying a branch via Cloud Build was removed; deploy it manually
# (e.g. `fly deploy -a gsr-code-review-staging` from that branch) and set:
# STAGING_URL="https://gsr-code-review-staging.fly.dev"

# ---- Evaluation Testing Configuration ----------------------
EVAL_TARGET_BRANCH=""
EVAL_COMPARISON_GROUP="local_vs_production"
PRODUCTION_URL="https://gsr-code-review.fly.dev"
GITHUB_TARGET_REPO="weitzer-org/gemini-cli-fork"
