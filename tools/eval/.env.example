# GSR Evaluation Testing Environment

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT="my-gcp-project-id" # E.g., quacktastic-waffle or weitzer-org
GCS_BUCKET="gsr-eval-results-my-gcp-project-id"

# Secret Manager Identifiers
GITHUB_PAT_SECRET="gsr-github-pat"
GEMINI_SECRET="gsr-gemini-api-key"

# CI / Deploy Configuration
CLOUD_BUILD_TRIGGER_ID="gsr-eval-staging"

# API Keys (Fallback if not using Secret Manager)
# GEMINI_API_KEY="AIza..."

# Evaluation Testing Configuration
EVAL_TARGET_BRANCH=""
EVAL_COMPARISON_GROUP="local_vs_production"
PRODUCTION_URL="https://gsr-code-review-*.run.app"
GITHUB_TARGET_REPO="weitzer-org/gemini-cli-fork"
